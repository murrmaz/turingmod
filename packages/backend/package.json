{
  "name": "@turingmod/backend",
  "version": "0.1.0",
  "description": "TuringMod backend server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "type-check": "tsc --noEmit",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "check": "biome check src",
    "check:fix": "biome check --write src"
  },
  "keywords": [
    "turingmod",
    "backend",
    "server"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "@turingmod/shared": "*",
    "@twurple/api": "^7.2.0",
    "@twurple/auth": "^7.2.0",
    "@twurple/chat": "^7.2.0",
    "@twurple/eventsub-base": "^7.2.0",
    "@twurple/eventsub-ws": "^7.2.0",
    "googleapis": "^173.0.0",
    "obs-websocket-js": "^5.0.7",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "sound-play": "^1.1.0",
    "sql.js": "^1.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/ws": "^8.5.13",
    "tsx": "^4.7.0",
    "typescript": "^6.0.0"
  }
}
